{
  "name": "@docwarden/cli-kit",
  "type": "module",
  "version": "0.0.0",
  "description": "Shared CLI runtime and command helpers for docwarden workspace CLIs",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "clean": "rm -rf dist",
    "dev": "tsdown --config tsdown.config.ts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/cli": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/printer": "catalog:",
    "@effect/printer-ansi": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}

{
  "name": "docwarden",
  "type": "module",
  "version": "0.0.0",
  "description": "Document maintenance CLI for agent-era documentation workflows",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "docwarden": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts && node ../../scripts/ensure-shebang.mjs dist/index.js",
    "clean": "rm -rf dist",
    "dev": "tsdown --config tsdown.config.ts --watch",
    "prepack": "pnpm build",
    "smoke:bin": "pnpm build && dist/index.js --help",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@docwarden/cli-kit": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
